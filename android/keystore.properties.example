# Copy this file to keystore.properties and fill in the real values.
# Do not commit keystore.properties or the .jks file.
# Keystore is in android/app/: @assemblie_assemblie.jks

MYAPP_RELEASE_STORE_FILE=@assemblie_assemblie.jks
MYAPP_RELEASE_KEY_ALIAS=your-key-alias
MYAPP_RELEASE_STORE_PASSWORD=your-store-password
MYAPP_RELEASE_KEY_PASSWORD=your-key-password
